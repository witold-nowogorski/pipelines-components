# Copy to .env and fill in your values. Used by integration tests (conftest.py).
# See tests/README.md for full descriptions.

# RHOAI pipeline API
RHOAI_KFP_URL=
RHOAI_TOKEN=
RHOAI_PROJECT_NAME=docrag-lite-integration-test

# Pipeline parameters (Kubernetes secret names and data locations; must exist in cluster)
TEST_DATA_SECRET_NAME=
TEST_DATA_BUCKET_NAME=
TEST_DATA_KEY=
INPUT_DATA_SECRET_NAME=
INPUT_DATA_BUCKET_NAME=
INPUT_DATA_KEY=

# Lite pipeline: chat and embedding model endpoints (OpenAI-compatible) and tokens
CHAT_MODEL_URL=
CHAT_MODEL_TOKEN=
EMBEDDING_MODEL_URL=
EMBEDDING_MODEL_TOKEN=

# S3-compatible storage for artifact checks (optional)
AWS_S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
RHOAI_TEST_ARTIFACTS_BUCKET=

# Optional: RHOAI_PIPELINE_RUN_TIMEOUT=3600, KFP_VERIFY_SSL=false
