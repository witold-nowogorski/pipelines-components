# Copy to .env and fill in your values. Used by integration tests (conftest.py).
# See README_integration.md for full descriptions.

# RHOAI pipeline API
RHOAI_URL=
RHOAI_KFP_URL=
# Service account token (e.g. from Jenkins credentials). Create with: oc create token <sa-name> -n <project>
RHOAI_TOKEN=
RHOAI_PROJECT_NAME=kfp-integration-test

# S3-compatible storage (e.g. MinIO or AWS S3)
AWS_S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
# Internal endpoint for S3 storage (e.g. MinIO in cluster), used for integration tests in disconnected env (optional)
AWS_S3_INTERNAL_ENDPOINT=
RHOAI_TEST_DATA_BUCKET=
RHOAI_TEST_ARTIFACTS_BUCKET=
RHOAI_TEST_S3_SECRET_NAME=s3-connection

# Optional: path to a pre-compiled pipeline YAML (skips on-the-fly compilation if set)
# RHOAI_COMPILED_PIPELINE_PATH=

# Optional: timeout in seconds for pipeline run (default 3600)
# RHOAI_PIPELINE_RUN_TIMEOUT=3600

# Optional: run only test configs with these tags (comma-separated). E.g. smoke, regression.
# RHOAI_TEST_CONFIG_TAGS=smoke

# Optional: create DataSciencePipelinesApplication CR in the test namespace via Kubernetes SDK
# Set to true/1 to create a DSPA CR; requires Data Science Pipelines Operator (DSPO) / Open Data Hub.
# When set, the KFP client URL is resolved from the OpenShift Route created by the operator.
# RHOAI_CREATE_DSPA=false
# Optional: override DSPA CRD identity (defaults: opendatahub.io v1alpha1)
# RHOAI_DSPA_API_GROUP=datasciencepipelinesapplications.opendatahub.io
# RHOAI_DSPA_API_VERSION=v1alpha1
# RHOAI_DSPA_PLURAL=datasciencepipelinesapplications
# Optional: route name prefix to find the pipeline API route (default: ds-pipeline)
# RHOAI_DSPA_ROUTE_NAME_PREFIX=ds-pipeline
# Optional: seconds to wait for the route to appear after creating DSPA (default: 300)
# RHOAI_DSPA_ROUTE_WAIT_TIMEOUT=300
# Optional: seconds to wait for DSPA status to become Ready (default: 600)
# RHOAI_DSPA_READY_WAIT_TIMEOUT=600
# Optional: extra seconds to wait after DSPA is Ready before using the API (default: 30)
# RHOAI_DSPA_READY_BUFFER_SECONDS=30
